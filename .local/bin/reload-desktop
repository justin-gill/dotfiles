#!/usr/bin/python3

import subprocess
import random
from pathlib import Path

CONFIG = {
    "config_path": Path("~/.config").expanduser(),
    "wallpaper_folder": Path("~/Pictures/wallpapers").expanduser(),
}

def flatten_dict(dictionary: dict, parent_key: str = '', separator: str = '_'):
    """Flatten nested dictionaries (same as your version)."""
    items = []
    for key, value in dictionary.items():
        new_key = parent_key + separator + key if parent_key else key
        if isinstance(value, dict):
            items.extend(flatten_dict(value, new_key, separator=separator).items())
        else:
            items.append((new_key, value))
    return dict(items)

def get_random_wallpaper(folder: Path) -> str:
    """Return a random image file path from the wallpaper folder."""
    image_extensions = {".jpg", ".jpeg", ".png", ".bmp", ".webp"}
    wallpapers = [f for f in folder.iterdir() if f.suffix.lower() in image_extensions]
    if not wallpapers:
        raise FileNotFoundError(f"No wallpapers found in {folder}")
    return str(random.choice(wallpapers))

if __name__ == "__main__":
    wallpaper = get_random_wallpaper(CONFIG["wallpaper_folder"])
    print(f"Setting wallpaper to: {wallpaper}")

    # Set wallpaper using awww
    subprocess.Popen([
        "awww", "img", wallpaper,
        "--transition-type=wipe",
        "--transition-fps=60"
    ])

    # Restart Waybar
    subprocess.run(["killall", "waybar"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.Popen(["waybar"])
