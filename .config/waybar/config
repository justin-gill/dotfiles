{
    "layer": "top",
    "position": "top",
    "height": 39,
    "spacing": 4,
    //"margin": "5 15 0 15",
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["network", "custom/tailscale", "pulseaudio", "bluetooth", "battery", "tray", "custom/power"],
    "hyprland/workspaces": {
        "format": "{icon}",
        "persistent-workspaces": {
            "*": [ 1,2,3,4 ]
        },
        "format-icons": {
            "active": "’åÆ",
            "default": "’æä",
        },
    },
    "bluetooth": {
        "format": "’Ŗō",
        "format-disabled": "¾░é▓",
        "on-click": "rfkill toggle bluetooth",
        "tooltip-format": "{status}"
    },
    "clock": {
        "timezone": "America/Los_Angeles",
        "format": "{:%b %d | %I:%M %p}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "smooth-scrolling-threshold": 5,
        "calendar": {
            "mode"          : "month",
            "mode-mon-col"  : 3,
            "on-scroll"     : 1,
            "format": {
                "months":     "<span color='#B2B2B2'><b>{}</b></span>",
                "days":       "<span color='#B2B2B2'><b>{}</b></span>",
                "weeks":      "<span color='#B2B2B2'><b>W{}</b></span>",
                "weekdays":   "<span color='#B2B2B2'><b>{}</b></span>",
                "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions":  {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "cpu": {
        "format": "{usage}% ’ŗø",
        "tooltip": false
    },
    "pulseaudio": {
        "scroll-step": 5,
        "format": "{volume}% {icon}",
        "format-muted": "Muted",
        "format-source": "{volume}% ’ä░",
        "format-source-muted": "’ä▒",
        "format-icons": {
            "default": ["’Ć”", "’Ć¦", "’Ć©"]
        },
        "on-click": "pavucontrol"
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ’ć”",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"],
        "interval": 5
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        "format-wifi": "{icon}  {essid}",
        "format-ethernet": " ¾░▓Ø ",
        "format-disconnected": "ŌÜĀ  Disconnected",
        "format-icons": ["¾░ż¤ ", "¾░żó ", "¾░żź "],
        "tooltip-format-wifi": "Signal: {signalStrength}% | IP: {ipaddr}",
        "tooltip-format-ethernet": "IP: {ipaddr} | {ifname}",
        "tooltip-format-disconnected": "Network offline",
        "on-click": "ghostty --class=com.ghostty.floating -e $HOME/.config/waybar/scripts/nmtui-colored"
    },
    "custom/power": {
        "format": "’Ćæ",
        "on-click": "$HOME/.config/rofi/bin/powermenu"
    },
    "custom/tailscale": {
        "format": "{}",
        "interval": 5,
        "exec": "$HOME/.config/waybar/scripts/info-tailscale",

    },
    "tray":{
        "icon-size":18,
        "spacing": 10
    },
}

