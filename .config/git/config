# XDG git config, remove ~/.gitconfig if exists so git will fallback here

[include]
    path = user.gitconfig # for local [user] block

[core]
    autocrlf = input
    safecrlf = true

[commit]
    verbose = true

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[fetch]
    prune = true

[init]
    defaultBranch = main

[alias]
    lg = log --graph --oneline
